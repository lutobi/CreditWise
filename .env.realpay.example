# Realpay Integration Environment Variables
# Copy these to your .env.local file

# ============================================
# Feature Flags (set to 'true' to enable)
# ============================================
NEXT_PUBLIC_REALPAY_ENABLED=false
NEXT_PUBLIC_REALPAY_AVS=false
NEXT_PUBLIC_REALPAY_DEBICHECK=false
NEXT_PUBLIC_REALPAY_PAYMENT_CALENDAR=false
REALPAY_PAYOUT_ENABLED=false

# ============================================
# Realpay API Configuration
# ============================================
# For development, use the mock server:
REALPAY_API_URL=http://localhost:4100

# For production, use the real Realpay API:
# REALPAY_API_URL=https://api.realpay.co.za

# API credentials (get from Realpay dashboard)
REALPAY_API_KEY=
REALPAY_MERCHANT_ID=
REALPAY_WEBHOOK_SECRET=

# ============================================
# Mock Server Configuration (development only)
# ============================================
MOCK_REALPAY_PORT=4100
WEBHOOK_TARGET=http://localhost:3000/api/realpay/webhooks
